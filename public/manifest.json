{
  "manifest_version": 3,
  "name": "MirrorBreaker Shell",
  "version": "1.0.0",
  "description": "Real-time deepfake detection overlay for video calls.",
  "permissions": ["activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://*.zoom.us/*"
      ],
      "js": ["assets/content.js"],
      "css": ["assets/content.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_title": "MirrorBreaker"
  }
}
